# RetroQuest Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=your-secret-key-here-change-in-production
AUTO_CREATE_SCHEMA_ON_START=1

# Database Configuration
# For development (SQLite)
DATABASE_URL=sqlite:///instance/database.db

# For production (PostgreSQL) - uncomment and modify
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/retroquest
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300

# Redis / cache / sessions
REDIS_URL=redis://localhost:6379/0
CACHE_TYPE=simple
CACHE_REDIS_URL=redis://localhost:6379/0
ENABLE_SERVER_SIDE_SESSIONS=0
SESSION_REDIS_URL=redis://localhost:6379/1
GAME_STATE_BACKEND=memory
GAME_STATE_PREFIX=retroquest:game

# Upload Configuration
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=16777216

# Admin Configuration
ADMIN_USER=admin
ADMIN_PASS=your-admin-password-here

# NowPayments Configuration
# Get your API key and IPN secret from https://nowpayments.io
# 1. Sign up at nowpayments.io
# 2. Specify your payout wallet
# 3. Generate API key and IPN secret key in Payment Settings
NOWPAYMENTS_API_KEY=98Z3XE1-RG74GVJ-JM8T50A-C18943N
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1/invoice
NOWPAYMENTS_IPN_SECRET=DxSy2thJ7uyjQZ6Kukvs12PfmoF04lqV
NOWPAYMENTS_CALLBACK_URL=https://tnno1111.onrender.com/webhook
NOWPAYMENTS_SUCCESS_URL=https://tnno1111.onrender.com/success
NOWPAYMENTS_CANCEL_URL=https://tnno1111.onrender.com/deposit

