# RetroQuest Environment Configuration
# Copy this file to .env and fill in your values

# Flask Configuration
FLASK_ENV=development
FLASK_APP=run.py
SECRET_KEY=your-secret-key-here-change-in-production
AUTO_CREATE_SCHEMA_ON_START=1

# Database Configuration
# For development (SQLite)
DATABASE_URL=sqlite:///instance/database.db

# For production (PostgreSQL) - uncomment and modify
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/retroquest
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300

# Redis / cache / sessions
REDIS_URL=redis://localhost:6379/0
CACHE_TYPE=simple
CACHE_REDIS_URL=redis://localhost:6379/0
ENABLE_SERVER_SIDE_SESSIONS=0
SESSION_REDIS_URL=redis://localhost:6379/1
GAME_STATE_BACKEND=memory
GAME_STATE_PREFIX=retroquest:game

# Upload Configuration
UPLOAD_FOLDER=static/uploads
MAX_CONTENT_LENGTH=16777216

# Admin Configuration
ADMIN_USER=admin
ADMIN_PASS=your-admin-password-here

# CloudPaya Configuration
CLOUDPAYA_API_KEY=your-cloudpaya-api-key-here
CLOUDPAYA_API_URL=https://api.cloudpaya.com/v1/payments
CLOUDPAYA_CALLBACK_URL=https://tnno1111.onrender.com/webhook
CLOUDPAYA_SUCCESS_URL=https://tnno1111.onrender.com/success
# Optional signature secret for webhook verification
CLOUDPAYA_WEBHOOK_SECRET=

# Blockchain Configuration
START_BLOCKCHAIN_CHECKER=0
BSC_RPC=https://bsc-dataseed.binance.org/
WALLET_ADDRESS=0x907049603cf15E888327e67BB56C7AAE0ED638Fb
USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955
USDT_TO_POINTS=4000
DEPOSIT_TIMEOUT=600

# Session Configuration
SESSION_COOKIE_SECURE=False
